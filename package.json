{
  "name": "dataspace-client-sdk-node",
  "version": "0.2.11",
  "description": "Node.js SDK for DIDComm plain batch + async polling flows",
  "license": "Apache-2.0",
  "author": "Antifraud Services Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Global-DataCare/dataspace-client-sdk-node.git"
  },
  "homepage": "https://github.com/Global-DataCare/dataspace-client-sdk-node#readme",
  "bugs": {
    "url": "https://github.com/Global-DataCare/dataspace-client-sdk-node/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "docs:generate-api": "node scripts/generate-sdk-api-docs.mjs",
    "docs:check-jsdoc": "node scripts/check-jsdoc-coverage.mjs",
    "docs:check-links": "node scripts/check-doc-links.mjs",
    "examples:check-gw-alignment": "node scripts/check-gw-example-alignment.mjs",
    "docs:validate": "npm run docs:check-jsdoc && npm run docs:generate-api && npm run docs:check-links && npm run examples:check-gw-alignment",
    "test": "npm run build && node --test tests/*.test.mjs",
    "example:e2e-bootstrap-tenant": "npm run build && node examples/e2e-bootstrap-tenant.mjs",
    "test:e2e:live-use-cases": "npm run build && RUN_LIVE_GW_E2E=1 node --test tests/live-gw-uc5.e2e.test.mjs",
    "test:e2e:live-gw-uc5": "npm run test:e2e:live-use-cases"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.6.1",
    "gdc-common-utils-ts": "^1.4.20",
    "node-fetch": "^3.3.2"
  }
}
